{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; script-src-attr 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    },
    {
      "source": "/:path((?!api/).*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://shamanism-research.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Vary", "value": "Origin" }
      ]
    },
    {
      "source": "/data/patchnotes.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/data/(.*).json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/api/stock-code",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=600, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/stock-price",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=120, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/warn-search",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=600, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/caution-search",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=120, stale-while-revalidate=60" }
      ]
    }
  ],
  "functions": {
    "api/telegram.py": { "maxDuration": 300 },
    "api/warn-search.py": { "maxDuration": 30 },
    "api/caution-search.py": { "maxDuration": 30 },
    "api/stock-price.py": { "maxDuration": 30 },
    "api/dart-search.py": { "maxDuration": 30 },
    "api/financial-model.py": { "maxDuration": 60 }
  }
}
