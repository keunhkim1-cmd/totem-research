{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "regions": ["icn1"],
  "crons": [
    { "path": "/api/warm-cache", "schedule": "10 7 * * 1-5" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'sha256-6PoeIMeJGmQIsGhuN0VMh0tTvCXwAh47k1WUILwhmxg='; script-src-attr 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    },
    {
      "source": "/:path((?!api/).*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://totem-research.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Vary", "value": "Origin" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/data/holidays.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/data/patchnotes.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=60, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/api/stock-code",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=600, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/stock-price",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=120, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/stock-overview",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=120, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/warn-search",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=600, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/caution-search",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, max-age=120, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/market-alert-forecast",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "functions": {
    "api/debug.py": { "maxDuration": 10 },
    "api/telegram.py": { "maxDuration": 120 },
    "api/stock-code.py": { "maxDuration": 20 },
    "api/stock-overview.py": { "maxDuration": 20 },
    "api/warn-search.py": { "maxDuration": 20 },
    "api/caution-search.py": { "maxDuration": 30 },
    "api/market-alert-forecast.py": { "maxDuration": 60 },
    "api/stock-price.py": { "maxDuration": 20 },
    "api/dart-search.py": { "maxDuration": 20 },
    "api/cache-bust.py": { "maxDuration": 10 },
    "api/warm-cache.py": { "maxDuration": 60 }
  }
}
